# MANIFEST.in is included as a workaround for current limitations in pyproject.toml
# (see e.g. https://github.com/pypa/setuptools/issues/3341)
exclude \
    .env* \
    .git* \
    .github\** \
    .vscode\* \
    .readthedocs.yaml \
    pytest.ini \
    data\** \
    docs\** \
    test\** \
    tmp\** \


global-exclude \
    *.py[cod]$ {2:.DS_Store} \
    *.egg-info\* \
#     _version.py \

